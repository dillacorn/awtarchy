#!/usr/bin/env bash
# github.com/dillacorn/awtarchy/tree/main/config/hypr/themes
# ~/.config/hypr/themes/catppuccin-frappé

# catppuccin-frappé

set -euo pipefail

###########   THEME COLORS   ###########
