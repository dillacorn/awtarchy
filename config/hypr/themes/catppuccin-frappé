W_BG="#303446"
W_HOVER="#ca9ee6"
W_FOCUS_BG="#ca9ee6"
W_ACTIVE_BG="#626880"
W_ACTIVE_COLOR="#c6d0f5"
W_URGENT_BG="#e78284"
W_URGENT_COLOR="#232634"
W_MODE_BG="#303446"
W_MODE_COLOR="#232634"
W_CUSTOM_HOVER_BG="#737994"
W_BATT_CHARGING_BG="#a6d189"
W_BATT_CHARGING_COLOR="#303446"
W_BATT_CRITICAL_BG="#ef9f76"
W_FOCUS="#83a598"
W_MUTED="#737994"

# Wlogout
WL_COLOR="#c6d0f5"
WL_BG="rgba(48, 52, 70, 0.76)"
WL_BTN_COLOR="#c6d0f5"
WL_BTN_BG="rgba(48, 52, 70, 0.76)"
WL_BTN_HOVER_BG="rgba(202, 158, 230, 0.92)"
WL_BTN_FOCUS_BG="rgba(202, 158, 230, 0.92)"

# Wofi
WO_BORDER="2px none #c6d0f5"
WO_BG="#303446"
WO_INPUT_COLOR="#c6d0f5"
WO_OUTER_BORDER="0px solid #c6d0f5"
WO_OUTER_BG="#303446"
WO_TEXT_UNSEL="#c6d0f5"

# Fuzzel
FZ_BACKGROUND="303446ff"
FZ_TEXT="c6d0f5ff"
FZ_SELECTION="c6d0f5ff"
FZ_SELECTION_TEXT="303446ff"
FZ_BORDER="c6d0f5ff"
FZ_MATCH="c6d0f5ff"
FZ_SELECTION_MATCH="303446ff"

# Mako
MKO_BG="#303446"
MKO_TEXT="#c6d0f5"
MKO_BORDER="#303446"
MKO_PROG="#ca9ee6"

###########   FILE PATHS   ###########
HYPR_LUA="$HOME/.config/hypr/hyprland.lua"
HYPR_CONF="$HOME/.config/hypr/hyprland.conf"
WAYBAR_CSS="$HOME/.config/waybar/style.css"
WLOGOUT_CSS="$HOME/.config/wlogout/style.css"
WOFI_CSS="$HOME/.config/wofi/style.css"
FUZZEL_THEME_INI="$HOME/.config/fuzzel/fuzzel.ini"
MAKO_CONF="$HOME/.config/mako/config"
MICRO_SETTINGS="$HOME/.config/micro/settings.json"
ALACRITTY_CONF="$HOME/.config/alacritty/alacritty.toml"
SPEEDCRUNCH_INI="$HOME/.config/SpeedCrunch/SpeedCrunch.ini"

###########   HELPERS   ###########
set_hypr_lua_border_colors() {
    local active_border="$1"
    local inactive_border="$2"

    python - "$HYPR_LUA" "$active_border" "$inactive_border" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
active = f"rgba({sys.argv[2]})"
inactive = f"rgba({sys.argv[3]})"

text = path.read_text()

def lua_quote(value: str) -> str:
    return '"' + value.replace("\\", "\\\\").replace('"', '\\"') + '"'

def replace_key(text: str, key: str, value: str) -> tuple[str, int]:
    pattern = re.compile(
        r'(^[ \t]*hl\.config\(\{\s*general\s*=\s*\{\s*col\s*=\s*\{\s*'
        + re.escape(key)
        + r'\s*=\s*)"[^"]*"(\s*\}\s*\}\s*\}\s*\)\s*$)',
        re.MULTILINE,
    )

    text, count = pattern.subn(
        lambda m: m.group(1) + lua_quote(value) + m.group(2),
        text,
    )

    comment_pattern = re.compile(
        r'(^[ \t]*--\s*col\.'
        + re.escape(key)
        + r'\s*=\s*)rgba\([^)]+\)',
        re.MULTILINE,
    )

    text = comment_pattern.sub(
        lambda m: m.group(1) + value,
        text,
    )

    return text, count

text, active_count = replace_key(text, "active_border", active)
text, inactive_count = replace_key(text, "inactive_border", inactive)

missing = []
if active_count == 0:
    missing.append("general.col.active_border")
if inactive_count == 0:
    missing.append("general.col.inactive_border")

if missing:
    raise SystemExit("ERROR: did not find native Lua config key(s): " + ", ".join(missing))

path.write_text(text)
PY
}

apply_hyprland_colors() {
    if [[ -f "$HYPR_LUA" ]]; then
        set_hypr_lua_border_colors "$NEW_ACTIVE_BORDER" "$NEW_INACTIVE_BORDER"

        lua -e 'assert(loadfile(os.getenv("HOME") .. "/.config/hypr/hyprland.lua"))' >/dev/null
        command -v hyprctl >/dev/null 2>&1 && hyprctl reload >/dev/null || true
        return 0
    fi

    if [[ -f "$HYPR_CONF" ]]; then
        sed -i \
            -e "s/^ *col\.active_border *= *.*/col.active_border = rgba(${NEW_ACTIVE_BORDER})/" \
            -e "s/^ *col\.inactive_border *= *.*/col.inactive_border = rgba(${NEW_INACTIVE_BORDER})/" \
            "$HYPR_CONF"

        command -v hyprctl >/dev/null 2>&1 && hyprctl reload >/dev/null || true
        return 0
    fi

    printf 'WARNING: no hyprland.lua or hyprland.conf found. Skipping Hyprland colors.\n' >&2
}

###########   APPLY CHANGES   ###########
echo "🔄 Applying theme..."

# Hyprland
apply_hyprland_colors

# Waybar
sed -i \
    -e "2s|.*|@define-color bg-default ${W_BG};|" \
    -e "3s|.*|@define-color bg-hover ${W_CUSTOM_HOVER_BG};|" \
    -e "4s|.*|@define-color bg-focus ${W_FOCUS_BG};|" \
    -e "5s|.*|@define-color bg-active ${W_ACTIVE_BG};|" \
    -e "6s|.*|@define-color bg-urgent ${W_URGENT_BG};|" \
    -e "7s|.*|@define-color bg-charging ${W_BATT_CHARGING_BG};|" \
    -e "8s|.*|@define-color bg-critical ${W_BATT_CRITICAL_BG};|" \
    -e "9s|.*|@define-color color-default ${W_COLOR};|" \
    -e "10s|.*|@define-color color-dark ${W_URGENT_COLOR};|" \
    -e "11s|.*|@define-color color-hover ${W_HOVER};|" \
    "$WAYBAR_CSS"

# Wlogout
sed -i \
    -e "4s|.*|    color: ${WL_COLOR};|" \
    -e "5s|.*|    background-color: ${WL_BG};|" \
    -e "13s|.*|    color: ${WL_BTN_COLOR};|" \
    -e "17s|.*|    background-color: ${WL_BG};|" \
    -e "23s|.*|    background-color: ${WL_BTN_HOVER_BG};|" \
    -e "27s|.*|    background-color: ${WL_BTN_FOCUS_BG};|" \
    "$WLOGOUT_CSS"

# Wofi
sed -i \
    -e "/^window[[:space:]]*{/,/^[[:space:]]*}/ s|^[[:space:]]*border:.*;|    border: ${WO_BORDER};|" \
    -e "/^window[[:space:]]*{/,/^[[:space:]]*}/ s|^[[:space:]]*background-color:.*;|    background-color: ${WO_BG};|" \
    -e "/^#input[[:space:]]*{/,/^[[:space:]]*}/ s|^[[:space:]]*color:.*;|    color: ${WO_INPUT_COLOR};|" \
    -e "/^#outer-box[[:space:]]*{/,/^[[:space:]]*}/ s|^[[:space:]]*border:.*;|    border: ${WO_OUTER_BORDER};|" \
    -e "/^#outer-box[[:space:]]*{/,/^[[:space:]]*}/ s|^[[:space:]]*background-color:.*;|    background-color: ${WO_OUTER_BG};|" \
    -e "/^#text/,/^[[:space:]]*}/ s|^[[:space:]]*color:.*;|    color: ${WO_TEXT_UNSEL};|" \
    "$WOFI_CSS"

# Mako
sed -i \
    -e "3s|.*|background-color=${MKO_BG}|" \
    -e "4s|.*|text-color=${MKO_TEXT}|" \
    -e "5s|.*|border-color=${MKO_BORDER}|" \
    -e "6s|.*|progress-color=over ${MKO_PROG}|" \
    "$MAKO_CONF"

# Micro
sed -i '2s|.*|    "colorscheme": "catppuccin-frappe-transparent"|' "$MICRO_SETTINGS"

# Alacritty
sed -i '331s|.*|  "~\/.config\/alacritty\/themes\/themes\/catppuccin_frappe.toml"|' "$ALACRITTY_CONF"

# SpeedCrunch
sed -i '5s|.*|Display\\ColorSchemeName=catppuccin-frappe|' "$SPEEDCRUNCH_INI"

# Fuzzel
sed -i \
  -e "2s|.*|background=${FZ_BACKGROUND}|" \
  -e "3s|.*|text=${FZ_TEXT}|" \
  -e "4s|.*|selection=${FZ_SELECTION}|" \
  -e "5s|.*|selection-text=${FZ_SELECTION_TEXT}|" \
  -e "6s|.*|selection-match=${FZ_BORDER}|" \
  -e "7s|.*|match=${FZ_MATCH}|" \
  -e "8s|.*|border=${FZ_SELECTION_MATCH}|" \
  "$FUZZEL_THEME_INI"

# Reload Mako
makoctl reload

echo "✅ theme applied!"
