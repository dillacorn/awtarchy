{
    "label": "lock",
    "action": "hyprlock",
    "text": "Lock (L)",
    "keybind": "l"
}
{
    "label": "hibernate",
    "action": "hyprlock & sleep 1; systemctl hibernate || loginctl hibernate",
    "text": "Hibernate (H)",
    "keybind": "h"
}
{
    "label": "reboot",
    "action": "systemctl reboot",
    "text": "Reboot (R)",
    "keybind": "r"
}
{
    "label": "shutdown",
    "action": "systemctl poweroff",
    "text": "Shutdown (S)",
    "keybind": "s"
}
{
    "label": "logout",
    "action": "loginctl kill-session $XDG_SESSION_ID",
    "text": "Logout (O)",
    "keybind": "o"
}
{
    "label": "suspend",
    "action": "hyprlock & sleep 1; systemctl suspend -i",
    "text": "Suspend (Z)",
    "keybind": "z"
}
