[
  {
    "position": "top",
    "height": 28,
    "spacing": 0,
    "reload_style_on_change": true,
    "modules-left": [
      "custom/apps",
      "hyprland/workspaces",
      "group/ws-arrows",
      "wlr/taskbar",
      "hyprland/scratchpad",
      "custom/hypr-submap",
      "custom/spacer-submap",
      "privacy"
    ],
    "modules-center": [
      "hyprland/window"
    ],
    "modules-right": [
      "custom/idle_inhibitor",
      "cpu",
      "custom/cputemp",
      "memory",
      "backlight",
      "battery",
      "wireplumber",
      "custom/clock-toggle",
      "tray",
      "custom/clipboard",
      "custom/mako_dnd",
      "custom/power"
    ],
    "custom/spacer-submap": {
      "format": "  ",
      "tooltip": false
    },
    "group/ws-arrows": {
      "orientation": "horizontal",
      "drawer": {
        "transition-duration": 200,
        "transition-left-to-right": true,
        "children-class": "ws-drawer"
      },
      "modules": [
        "custom/ws-hub",
        "custom/ws-up",
        "custom/ws-down",
        "custom/ws-left",
        "custom/ws-right"
      ]
    },
    "custom/ws-hub": {
      "format": "рџ–±",
      "tooltip": true,
      "tooltip-format": "Toggle mouse submap",
      "on-click": "bash -lc \"s=$(hyprctl submap 2>/dev/null | tr -d '\\\\r'); if printf '%s\\n' \\\"$s\\\" | grep -q mouse; then hyprctl eval 'hl.dispatch(hl.dsp.submap(\\\"reset\\\"))'; truncate -s 0 /tmp/hypr-submap; else printf '%s\\n' mouse > /tmp/hypr-submap; hyprctl eval 'hl.dispatch(hl.dsp.submap(\\\"mouse\\\"))'; fi; pkill -RTMIN+12 waybar 2>/dev/null || true\"",
      "on-click-right": "bash -lc \"s=$(hyprctl submap 2>/dev/null | tr -d '\\\\r'); if printf '%s\\n' \\\"$s\\\" | grep -q mouse; then hyprctl eval 'hl.dispatch(hl.dsp.submap(\\\"reset\\\"))'; truncate -s 0 /tmp/hypr-submap; else printf '%s\\n' mouse > /tmp/hypr-submap; hyprctl eval 'hl.dispatch(hl.dsp.submap(\\\"mouse\\\"))'; fi; pkill -RTMIN+12 waybar 2>/dev/null || true\""
    },
    "custom/ws-left": {
      "format": "в†ђ",
      "tooltip": true,
      "tooltip-format": "Move workspace LEFT",
      "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.workspace.move({ monitor = \"l\" }))'"
    },
    "custom/ws-right": {
      "format": "в†’",
      "tooltip": true,
      "tooltip-format": "Move workspace RIGHT",
      "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.workspace.move({ monitor = \"r\" }))'"
    },
    "custom/ws-up": {
      "format": "в†‘",
      "tooltip": true,
      "tooltip-format": "Move workspace UP",
      "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.workspace.move({ monitor = \"u\" }))'"
    },
    "custom/ws-down": {
      "format": "в†“",
      "tooltip": true,
      "tooltip-format": "Move workspace DOWN",
      "on-click": "hyprctl eval 'hl.dispatch(hl.dsp.workspace.move({ monitor = \"d\" }))'"
    },
    "hyprland/workspaces": {
      "all-outputs": false,
      "warp-on-scroll": false,
      "enable-bar-scroll": true,
      "disable-scroll-wraparound": true,
      "format": "{icon}",
      "format-icons": {
        "1": "1вЂЇу°ћ·",
        "2": "2вЂЇп‰©",
        "3": "3вЂЇп‚•",
        "4": "4вЂЇп†¶",
        "5": "5вЂЇпЂЁ",
        "6": "6вЂЇп‚†",
        "7": "7вЂЇпЃ­",
        "8": "8вЂЇпѓґ",
        "9": "9вЂЇпЂѕ",
        "10": "10вЂЇпЂЅ"
      }
    },
    "hyprland/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": false,
      "format-icons": [
        "",
        "п‹’"
      ],
      "tooltip": true,
      "tooltip-format": "{app}: {title}"
    },
    "custom/hypr-submap": {
      "exec": "sh -c 'if [ -s /tmp/hypr-submap ]; then cat /tmp/hypr-submap; else echo \"\"; fi'",
      "interval": 1,
      "format": "{}",
      "tooltip": true,
      "tooltip-format": "Current submap: {} (click to reset)",
      "on-click": "sh -c 'truncate -s 0 /tmp/hypr-submap; hyprctl dispatch \"hl.dsp.submap(\\\"reset\\\")\"'",
      "on-click-right": "sh -c 'truncate -s 0 /tmp/hypr-submap; hyprctl dispatch \"hl.dsp.submap(\\\"reset\\\")\"'"
    },
    "hyprland/window": {
      "format": "{title}",
      "max-length": 40,
      "all-outputs": true
    },
    "wlr/taskbar": {
      "format": "{icon}",
      "tooltip-format": "{title}",
      "icon-size": 14,
      "all-outputs": false,
      "on-click": "activate",
      "on-click-middle": "close",
      "on-click-right": "minimize-raise",
      "ignore-list": [
        "wofi",
        "fuzzel",
        "tofi",
        "rofi",
        "mako",
        "wlogout",
        "hyprlock",
        "swaylock",
        "swww",
        "mpvpaper",
        "Pulsemixer",
        "org.Waytrogen.Waytrogen",
        "org.pulseaudio.pavucontrol",
        "Wiremix"
      ]
    },
    "custom/idle_inhibitor": {
      "exec": "~/.config/waybar/scripts/idle_inhibitor_global.sh",
      "interval": 1,
      "return-type": "json",
      "signal": 13,
      "on-click": "~/.config/waybar/scripts/idle_inhibitor_global.sh toggle",
      "on-click-right": "~/.config/waybar/scripts/idle_inhibitor_global.sh toggle",
      "tooltip": true
    },
    "tray": {
      "icon-size": 14,
      "spacing": 10
    },
    "custom/apps": {
      "on-click": "~/.config/hypr/scripts/fuzzel_toggle.sh --from-waybar --focus-loss-exit",
      "on-click-right": "~/.config/hypr/scripts/fuzzel_toggle.sh --from-waybar",
      "format": "пЂє",
      "tooltip": true,
      "tooltip-format": "app-launcher"
    },
    "custom/clock-toggle": {
      "exec": "~/.config/waybar/scripts/clock_toggle.sh",
      "interval": 30,
      "return-type": "json",
      "signal": 12,
      "on-click": "~/.config/waybar/scripts/clock_toggle.sh toggle",
      "on-click-right": "~/.config/waybar/scripts/clock_toggle.sh toggle",
      "on-scroll-up": "~/.config/waybar/scripts/clock_toggle.sh toggle",
      "on-scroll-down": "~/.config/waybar/scripts/clock_toggle.sh toggle",
      "tooltip": true,
      "exec-on-event": true
    },
    "custom/clipboard": {
      "format": "пЊЁ",
      "tooltip": false,
      "on-click": "~/.config/hypr/scripts/cliphist-fuzzel.sh &",
      "on-click-right": "~/.config/hypr/scripts/cliphist-fuzzel.sh &",
      "interval": 0
    },
    "custom/mako_dnd": {
      "exec": "~/.config/waybar/scripts/mako_dnd.sh",
      "interval": 30,
      "return-type": "json",
      "signal": 14,
      "on-click": "~/.config/waybar/scripts/mako_dnd.sh toggle",
      "tooltip": true
    },
    "custom/power": {
      "on-click": "~/.config/hypr/scripts/wlogout_toggle.sh &",
      "on-click-right": "~/.config/hypr/scripts/wlogout_toggle.sh &",
      "format": "пЂ‘",
      "tooltip": true,
      "tooltip-format": "wlogout"
    },
    "cpu": {
      "format": "{usage} п‹›",
      "tooltip": true
    },
    "memory": {
      "format": "{} пѓ‰ "
    },
    "custom/cputemp": {
      "exec": "~/.config/waybar/scripts/cpu_temp.sh",
      "interval": 2,
      "format": "{}",
      "tooltip": false
    },
    "backlight": {
      "format": "{icon} {percent}",
      "format-icons": [
        "оЋЌ",
        "оЏ“",
        "оЏ‘",
        "оЏЏ",
        "оЏЋ",
        "оЏЌ",
        "оЏЉ",
        "оЏ€",
        "оЋ›"
      ]
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}",
      "format-full": "{icon} {capacity}",
      "format-charging": "п—§ {capacity}",
      "format-plugged": "п‡¦ {capacity}",
      "format-alt": "{icon} {time}",
      "format-icons": [
        "п‰„",
        "п‰ѓ",
        "п‰‚",
        "п‰Ѓ",
        "п‰Ђ"
      ]
    },
    "wireplumber": {
      "scroll-step": 5,
      "format": "{icon}   {volume}",
      "format-bluetooth": "{icon} {volume} пЉ”",
      "format-bluetooth-muted": "пЂЌ {icon}пЉ”",
      "format-muted": "пЂЌ mute",
      "format-icons": {
        "headphone": "пЂҐ",
        "hands-free": "п–ђ",
        "headset": "п–ђ",
        "phone": "п‚•",
        "portable": "п‚•",
        "car": "п†№",
        "default": [
          "пЂ¦",
          "пЂ§",
          "пЂЁ"
        ]
      },
      "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
      "on-click-right": "exec ~/.config/waybar/scripts/wiremix-toggle.sh"
    }
  }
]
